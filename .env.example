# Copy to .env and fill in. Do not commit .env with real keys.

# OpenAI (used when online — app will use OpenAI for AI assistant)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: local Ollama (used when OpenAI is not set or request fails)
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: Flask
# FLASK_SECRET_KEY=your-secret
# FLASK_DEBUG=1

# Optional: MAVLink default connection
# MAVLINK_CONNECTION=udp:127.0.0.1:14550
